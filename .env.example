# =============================================================================
# TCC - Configuração de Variáveis de Ambiente
# =============================================================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env: copy .env.example .env
# 2. Preencha os valores abaixo com suas credenciais
# 3. NUNCA commite o arquivo .env no repositório!
#
# =============================================================================

# --- Configuração Obrigatória ---
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=sua_chave_api_aqui

# --- Configuração do Modelo LLM ---
# Modelos atuais (Google AI Studio): gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro
# Não use "models/" no nome - a API adiciona automaticamente
LLM_MODEL=gemini-2.0-flash
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# --- Configuração do Servidor ---
HOST=127.0.0.1
PORT=8000
DEBUG=false

# --- Configuração de CORS ---
# Em produção, especifique os domínios permitidos separados por vírgula
# Exemplo: CORS_ORIGINS=https://meusite.com,https://app.meusite.com
CORS_ORIGINS=*

# --- Configuração de Logging ---
# Níveis: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
